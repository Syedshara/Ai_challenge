# ================================================================
# Query Intelligence Engine — LLM Provider Configuration
# ================================================================
# Switch provider by changing the three LLM_* lines only.
# Everything else (embeddings, RAG, cache) is provider-independent
# and never changes regardless of which LLM you use.
#
# IMPORTANT: Copy your chosen block into .env — never commit .env.
#            Only this file (.env.example) belongs in version control.
# ================================================================


# ── Option 1: Groq (recommended for submission — free tier, fast) ─
# Sign up : https://console.groq.com
# Tool calling: llama-3.3-70b-versatile supports function calling
#
# LLM_API_KEY=gsk_your_groq_key_here
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=https://api.groq.com/openai/v1


# ── Option 2: OpenAI ──────────────────────────────────────────────
# Sign up : https://platform.openai.com
# o3-mini supports thinking + tool calling
#
# LLM_API_KEY=sk-your-openai-key-here
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=
# (leave LLM_BASE_URL blank — SDK uses OpenAI default endpoint)


# ── Option 3: Google Gemini ───────────────────────────────────────
# Sign up : https://aistudio.google.com
# Gemini exposes an OpenAI-compatible endpoint natively
#
# LLM_API_KEY=AIza-your-gemini-key-here
# LLM_MODEL=gemini-2.0-flash
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/


# ── Option 4: Anthropic Claude (via OpenRouter) ───────────────────
# OpenRouter wraps Claude in an OpenAI-compatible API — zero code change.
# Sign up : https://openrouter.ai
#
# LLM_API_KEY=sk-or-your-openrouter-key-here
# LLM_MODEL=anthropic/claude-3.5-sonnet
# LLM_BASE_URL=https://openrouter.ai/api/v1


# ── Option 5: DeepSeek ────────────────────────────────────────────
# OpenAI-compatible. deepseek-reasoner is a thinking model (R1).
# Sign up : https://platform.deepseek.com
#
# LLM_API_KEY=your-deepseek-key-here
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com/v1
#
# For thinking (slower, deeper reasoning):
# LLM_MODEL=deepseek-reasoner


# ── Option 6: Ollama — fully local, no API key ────────────────────
# Install : https://ollama.ai — then: ollama pull llama3.2
#
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2
# LLM_BASE_URL=http://localhost:11434/v1


# ── Option 7: Offline — no LLM at all ────────────────────────────
# Leave LLM_API_KEY blank. System runs fully on rule engine + RAG
# + cross-encoder reranking. No LLM calls made at all.
#
# LLM_API_KEY=
# LLM_MODEL=
# LLM_BASE_URL=


# ================================================================
# Tool-Calling + Thinking Model Compatibility
# ================================================================
# The ReAct agent loop uses OpenAI function/tool calling.
# The system automatically handles <think> blocks from thinking
# models — no configuration needed. Just pick the model.
#
#  Provider      Model                          Tool calling  Thinking
#  ──────────────────────────────────────────────────────────────────
#  Groq          llama-3.3-70b-versatile        ✓             —
#  OpenAI        gpt-4o-mini                    ✓             —
#  OpenAI        o3-mini                        ✓             ✓
#  Gemini        gemini-2.0-flash               ✓             —
#  Gemini        gemini-2.0-flash-thinking      ✓             ✓
#  Claude        anthropic/claude-3.5-sonnet    ✓             —
#  Claude        anthropic/claude-3.7-sonnet    ✓             ✓
#  DeepSeek      deepseek-chat                  ✓             —
#  DeepSeek      deepseek-reasoner (R1)         ✓             ✓
#  Siemens AI    qwen3-30b-a3b-instruct-2507    ✓             —
#  Siemens AI    qwen3-30b-a3b-thinking-2507    ✓             ✓
#  Ollama        llama3.2 / qwen2.5-coder       ✓             —
#
# If the chosen model does not support tool calling, the system
# automatically falls back to the deterministic fixed pipeline
# (rule engine + RAG, no LLM reasoning).
# ================================================================


# ── Shared settings — same across all providers ──────────────────

EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CHROMA_PERSIST_DIR=chroma_db

KNOWLEDGE_BASE_PATH=data/knowledge_base.json
SCHEMAS_PATH=data/schemas.json
METRICS_PATH=data/metrics_history.json
PATTERNS_PATH=data/query_patterns.json
FEEDBACK_LOG_PATH=data/feedback_log.json

CACHE_THRESHOLD=0.95
CACHE_MAX_SIZE=100

RAG_TOP_K_RETRIEVE=10
RAG_TOP_K_RERANK=3

ANOMALY_ZSCORE_THRESHOLD=3.0
ANOMALY_IQR_FACTOR=1.5
ANOMALY_WINDOW_SIZE=5

AGENT_MAX_STEPS=3


# ── MySQL Live Monitor — docker-compose.yml starts MySQL on port 3307 ────
# Run: docker-compose up -d && python demo_live.py
#
# MYSQL_HOST=localhost
# MYSQL_PORT=3307
# MYSQL_USER=monitor
# MYSQL_PASSWORD=monitor_pw
# MYSQL_DATABASE=employees
# MONITOR_SLOW_THRESHOLD_MS=500.0
